# Agentic QA
# Environment variables — copy to .env and fill in values

# Required
OPENAI_API_KEY=sk-...

# Optional — override model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Optional — how many test cases the Planner should aim for per target
MAX_TEST_CASES=10

# Optional — directory where reports are written (default: ./reports)
REPORTS_DIR=./reports
