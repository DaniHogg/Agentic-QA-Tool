# Agentic QA
# Environment variables — copy to .env and fill in values

# Required provider selection: openai | anthropic
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — how many test cases the Planner should aim for per target
MAX_TEST_CASES=10

# Optional — directory where reports are written (default: ./reports)
REPORTS_DIR=./reports
